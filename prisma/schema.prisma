generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  SUPER_ADMIN
}


model Teacher {
  id        String     @id @default(uuid())
  name      String
  nameMm    String?    @map("name_mm")
  bio       String?
  bioMm     String?    @map("bio_mm")
  image     String?
  title     String?
  teachings Teaching[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("teachers")
}

model Event {
  id            String           @id @default(uuid())
  title         String
  titleMm       String?          @map("title_mm")
  description   String?
  descriptionMm String?          @map("description_mm")
  date          DateTime
  endDate       DateTime?        @map("end_date")
  location      String?
  image         String?
  mainSponsor   String?          @map("main_sponsor")
  mainSponsorMm String?          @map("main_sponsor_mm")
  coSponsors    Json?            @map("co_sponsors") // Array of { name: string, nameMm: string }
  isActive      Boolean          @default(true) @map("is_active")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  inquiries     ContactInquiry[]

  @@map("events")
  @@index([date])
  @@index([isActive])
}

model Teaching {
  id            String                @id @default(uuid())
  title         String?
  titleMm       String?               @map("title_mm")
  content       String?
  contentMm     String?               @map("content_mm")
  category      String                @default("dhamma")
  coverImageUrl String?               @map("cover_image_url")
  audioUrl      String?               @map("audio_url")
  videoUrl      String?               @map("video_url")
  documentUrl   String?               @map("document_url")
  documentName  String?               @map("document_name")
  documentType  String?               @map("document_type")
  documentSize  Int?                  @map("document_size")
  teacherId     String?               @map("teacher_id")
  teacher       Teacher?              @relation(fields: [teacherId], references: [id])
  translations  TeachingTranslation[]
  isPublished   Boolean               @default(true) @map("is_published")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@map("teachings")
  @@index([category])
  @@index([isPublished])
  @@index([createdAt])
}

model TeachingTranslation {
  id         String   @id @default(uuid())
  teachingId String   @map("teaching_id")
  locale     String
  title      String
  content    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  teaching Teaching @relation(fields: [teachingId], references: [id], onDelete: Cascade)

  @@unique([teachingId, locale])
  @@index([locale])
  @@map("teaching_translations")
}

model Donation {
  id        String   @id @default(uuid())
  donorName String   @map("donor_name")
  amount    Float
  currency  String   @default("MMK")
  category  String   @default("general")
  message   String?
  slipUrl   String?  @map("slip_url")
  status    String   @default("approved") // pending, approved, rejected
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("donations")
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model MonthlyDonor {
  id        String    @id @default(uuid())
  name      String
  phone     String?
  amount    Float
  currency  String    @default("MMK")
  category  String    @default("general")
  startDate DateTime  @map("start_date")
  endDate   DateTime? @map("end_date")
  status    String    @default("pending") // pending, active, inactive
  remarks   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("monthly_donors")
  @@index([status])
  @@index([category])
}

model ContactInquiry {
  id          String   @id @default(uuid())
  name        String
  email       String?
  subject     String
  message     String
  isRead      Boolean  @default(false) @map("is_read")
  status      String   @default("pending") // pending, approved, rejected
  sponsorType String?  @map("sponsor_type") // main, co_sponsor
  eventId     String?  @map("event_id")
  event       Event?   @relation(fields: [eventId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("contact_inquiries")
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  description String?
  youtubeId   String   @map("youtube_id")
  category    String
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("lessons")
  @@index([category])
  @@index([published])
  @@index([createdAt])
}

